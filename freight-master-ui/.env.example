# Freight Master UI (Vite / Lovable) — copy to `.env` in this project only.
#
# Rules: only VITE_* in this file. Never DATABASE_URL / AUTH_SECRET / AUTH_URL (API server only).
# Do not duplicate variable names (last one wins).

# Local: API on port 3000. Lovable preview is HTTPS — if mixed content blocks localhost, use HTTPS URL below.
VITE_API_BASE_URL=http://localhost:3000
VITE_API_URL=http://localhost:3000

# Deployed or tunneled API (uncomment and replace when needed):
# VITE_API_BASE_URL=https://your-api.vercel.app
# VITE_API_URL=https://your-api.vercel.app
