# PostgreSQL (local or hosted)
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/freight_master"

# Auth.js — generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-long-random-string"
AUTH_URL="http://localhost:3000"

# Optional: object storage for uploads (future)
# S3_BUCKET=
# S3_REGION=

# --- API for Lovable / Vite UI (cross-origin) ---
# Allow browser requests from the UI dev server or Lovable preview (comma-separated origins).
CORS_ORIGINS="http://localhost:8080,http://localhost:5173"
# Read-only JSON API at /api/v1/* (shipments, etc.). Defaults on in development; set "false" to disable anywhere, or "true" to enable in production builds.
# FMP_PUBLIC_READ_API="true"
