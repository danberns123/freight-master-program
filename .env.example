# PostgreSQL (local or hosted)
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/freight_master"

# Auth.js — generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-long-random-string"
AUTH_URL="http://localhost:3000"

# Optional: object storage for uploads (future)
# S3_BUCKET=
# S3_REGION=

# --- API for Lovable / Vite UI (cross-origin) ---
# Exact origins (comma-separated). Lovable preview URLs change; use CORS_ALLOW_LOVABLE_PREVIEWS instead of pasting each preview URL.
CORS_ORIGINS="http://localhost:8080,http://localhost:5173"
# Allow Lovable preview origins (*.lovable.app / *.lovable.dev) without listing each preview URL.
CORS_ALLOW_LOVABLE_PREVIEWS="true"
# Read-only JSON at /api/v1/* — set "true" for production when the UI calls from Lovable; "false" to lock down.
FMP_PUBLIC_READ_API="true"
